generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String          @db.VarChar(255)
  email      String          @unique @db.VarChar(255)
  password   String          @db.VarChar(255)
  isAdmin    Boolean         @default(false) @map("is_admin")
  createdAt  DateTime        @default(now()) @map("created_at")
  reports    Report[]
  payments   Payment[]
  agreements UserAgreement[]

  @@map("users")
}

model Report {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  url        String   @db.VarChar(2048)
  urlHash    String   @map("url_hash") @db.VarChar(64)
  radiusMi   Int      @map("radius_mi")
  reportData Json     @map("report_data")
  paidAmount Int      @default(9900) @map("paid_amount")
  stripePi   String?  @map("stripe_pi") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  reportType String   @default("competitive") @map("report_type") @db.VarChar(20)
  city       String?  @db.VarChar(100)
  state      String?  @db.VarChar(100)
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, urlHash], name: "idx_reports_user_url")
  @@map("reports")
}

model UrlScoreCache {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  urlHash      String   @unique @map("url_hash") @db.VarChar(64)
  url          String   @db.VarChar(2048)
  overallScore Int      @map("overall_score")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("url_score_cache")
}

model UserAgreement {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  agreementVersion String   @default("1.0") @map("agreement_version") @db.VarChar(10)
  signedAt         DateTime @default(now()) @map("signed_at")
  ipAddress        String?  @map("ip_address") @db.VarChar(45)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_agreements")
}

model Payment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  stripepiId   String   @unique @map("stripe_pi_id") @db.VarChar(255)
  amountCents  Int      @map("amount_cents")
  status       String   @db.VarChar(50)
  reportUrl    String?  @map("report_url") @db.VarChar(2048)
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id])

  @@map("payments")
}

model AdminLead {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessName       String    @map("business_name")
  category           String
  subCategory        String?   @map("sub_category")
  rating             Float
  reviewCount        Int       @map("review_count")
  ratingTrend        String    @map("rating_trend")
  reviewResponseRate String?   @map("review_response_rate")
  primarySource      String    @map("primary_source")
  address            String?
  city               String
  state              String
  zipCode            String?   @map("zip_code")
  phone              String?
  website            String?
  email              String?
  ownerName          String?   @map("owner_name")
  contactFound       Boolean   @default(false) @map("contact_found")
  hasOnlineOrdering  Boolean?  @map("has_online_ordering")
  hasSocialMedia     Boolean?  @map("has_social_media")
  lastReviewDate     String?   @map("last_review_date")
  conversionScore    Int       @default(0) @map("conversion_score")
  competitors        Json?
  teaserFindings     Json?     @map("teaser_findings")
  fullFindings       Json?     @map("full_findings")
  teaserReport       Json?     @map("teaser_report")
  status             String    @default("discovered")
  teaserSentAt       DateTime? @map("teaser_sent_at")
  teaserClickedAt    DateTime? @map("teaser_clicked_at")
  convertedAt        DateTime? @map("converted_at")
  discoveredAt       DateTime  @default(now()) @map("discovered_at")
  discoveredBy       String?   @map("discovered_by") @db.Uuid

  @@index([category])
  @@index([category, state])
  @@index([category, state, city])
  @@index([status])
  @@index([conversionScore])
  @@map("admin_leads")
}

model Lead {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String
  firstName     String?   @map("first_name")
  businessName  String?   @map("business_name")
  analyzedUrl   String    @map("analyzed_url")
  reportId      String?   @map("report_id") @db.Uuid
  reportData    Json?     @map("report_data")
  utmSource     String?   @map("utm_source")
  utmMedium     String?   @map("utm_medium")
  utmCampaign   String?   @map("utm_campaign")
  referrer      String?
  ipCountry     String?   @map("ip_country")
  status        String    @default("captured")
  dripTag       String?   @map("drip_tag")
  convertedAt   DateTime? @map("converted_at")
  paidAmount    Int?      @map("paid_amount")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([email, analyzedUrl], name: "idx_leads_email_url")
  @@index([email])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("leads")
}
