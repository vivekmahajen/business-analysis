generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String              @db.VarChar(255)
  email              String              @unique @db.VarChar(255)
  password           String              @db.VarChar(255)
  isAdmin            Boolean             @default(false) @map("is_admin")
  createdAt          DateTime            @default(now()) @map("created_at")
  plan               String              @default("free") @db.VarChar(20)
  creditsRemaining   Int                 @default(3) @map("credits_remaining")
  stripeCustomerId   String?             @map("stripe_customer_id") @db.VarChar(255)
  stripeSubId        String?             @map("stripe_sub_id") @db.VarChar(255)
  planExpiresAt      DateTime?           @map("plan_expires_at")
  reports            Report[]
  payments           Payment[]
  agreements         UserAgreement[]
  creditTxns         CreditTransaction[]
  subEvents          SubscriptionEvent[]
  creditPurchases    CreditPurchase[]
  resetTokens        PasswordResetToken[]
  llmAudits          LlmAudit[]
  apiKeys            ApiKey[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model CreditTransaction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  delta     Int
  reason    String   @db.VarChar(100)
  reportId  String?  @map("report_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("credit_transactions")
}

model SubscriptionEvent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  stripeEventId  String   @unique @map("stripe_event_id") @db.VarChar(255)
  eventType      String   @map("event_type") @db.VarChar(100)
  plan           String   @db.VarChar(20)
  creditsGranted Int?     @map("credits_granted")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("subscription_events")
}

model CreditPurchase {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  stripeSessionId  String   @unique @map("stripe_session_id") @db.VarChar(255)
  creditsPurchased Int      @map("credits_purchased")
  amountCents      Int      @map("amount_cents")
  createdAt        DateTime @default(now()) @map("created_at")
  user             User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("credit_purchases")
}

model Report {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  url        String   @db.VarChar(2048)
  urlHash    String   @map("url_hash") @db.VarChar(64)
  radiusMi   Int      @map("radius_mi")
  reportData Json     @map("report_data")
  paidAmount Int      @default(9900) @map("paid_amount")
  stripePi   String?  @map("stripe_pi") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  reportType String   @default("competitive") @map("report_type") @db.VarChar(20)
  city       String?  @db.VarChar(100)
  state      String?  @db.VarChar(100)
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, urlHash], name: "idx_reports_user_url")
  @@map("reports")
}

model UrlScoreCache {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  urlHash      String   @unique @map("url_hash") @db.VarChar(64)
  url          String   @db.VarChar(2048)
  overallScore Int      @map("overall_score")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("url_score_cache")
}

model UserAgreement {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  agreementVersion String   @default("1.0") @map("agreement_version") @db.VarChar(10)
  signedAt         DateTime @default(now()) @map("signed_at")
  ipAddress        String?  @map("ip_address") @db.VarChar(45)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_agreements")
}

model Payment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  stripepiId   String   @unique @map("stripe_pi_id") @db.VarChar(255)
  amountCents  Int      @map("amount_cents")
  status       String   @db.VarChar(50)
  reportUrl    String?  @map("report_url") @db.VarChar(2048)
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id])

  @@map("payments")
}

model LlmAudit {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  businessName   String           @map("business_name")
  businessUrl    String?          @map("business_url")
  city           String
  state          String
  category       String
  status         String           @default("pending")
  overallScore   Int?             @map("overall_score")
  scoreBreakdown Json?            @map("score_breakdown")
  totalQueries   Int              @default(0) @map("total_queries")
  mentionCount   Int              @default(0) @map("mention_count")
  errorMessage   String?          @map("error_message")
  createdAt      DateTime         @default(now()) @map("created_at")
  completedAt    DateTime?        @map("completed_at")
  user           User             @relation(fields: [userId], references: [id])
  results        LlmAuditResult[]

  @@index([userId])
  @@map("llm_audits")
}

model LlmAuditResult {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  auditId        String   @map("audit_id") @db.Uuid
  provider       String   @db.VarChar(50)
  queryCategory  String   @map("query_category") @db.VarChar(100)
  query          String   @db.Text
  responseText   String   @map("response_text") @db.Text
  mentioned      Boolean
  mentionRank    Int?     @map("mention_rank")
  mentionContext String?  @map("mention_context") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  audit          LlmAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([auditId])
  @@map("llm_audit_results")
}

model LlmWaitlist {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email       String   @unique @db.VarChar(255)
  name        String?  @db.VarChar(255)
  businessUrl String?  @map("business_url") @db.VarChar(2048)
  city        String?  @db.VarChar(100)
  state       String?  @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("llm_waitlist")
}

model ApiKey {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  keyHash        String    @unique @map("key_hash") @db.VarChar(64)
  keyPrefix      String    @map("key_prefix") @db.VarChar(12)
  name           String?   @db.VarChar(100)
  plan           String    @default("free") @db.VarChar(20)
  source         String    @default("direct") @db.VarChar(20)
  callsThisMonth Int       @default(0) @map("calls_this_month")
  callsTotal     BigInt    @default(0) @map("calls_total")
  lastUsedAt     DateTime? @map("last_used_at")
  expiresAt      DateTime? @map("expires_at")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  user           User      @relation(fields: [userId], references: [id])
  jobs           ApiJob[]
  webhooks       ApiWebhook[]
  usageLogs      ApiUsageLog[]

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

model ApiJob {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apiKeyId        String    @map("api_key_id") @db.Uuid
  url             String    @db.VarChar(2048)
  radiusMi        Int       @default(25) @map("radius_mi")
  reportDepth     String    @default("standard") @map("report_depth") @db.VarChar(20)
  status          String    @default("queued") @db.VarChar(20)
  currentStep     String?   @map("current_step") @db.VarChar(50)
  percentComplete Int       @default(0) @map("percent_complete")
  reportId        String?   @map("report_id") @db.Uuid
  errorCode       String?   @map("error_code") @db.VarChar(50)
  errorMessage    String?   @map("error_message") @db.Text
  webhookUrl      String?   @map("webhook_url") @db.VarChar(2048)
  metadata        Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")
  apiKey          ApiKey    @relation(fields: [apiKeyId], references: [id])

  @@index([apiKeyId])
  @@map("api_jobs")
}

model ApiWebhook {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apiKeyId      String    @map("api_key_id") @db.Uuid
  url           String    @db.VarChar(2048)
  events        String[]
  signingSecret String    @map("signing_secret") @db.VarChar(64)
  isActive      Boolean   @default(true) @map("is_active")
  failureCount  Int       @default(0) @map("failure_count")
  lastSuccessAt DateTime? @map("last_success_at")
  lastFailureAt DateTime? @map("last_failure_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  apiKey        ApiKey    @relation(fields: [apiKeyId], references: [id])
  deliveries    ApiWebhookDelivery[]

  @@index([apiKeyId])
  @@map("api_webhooks")
}

model ApiWebhookDelivery {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  webhookId   String     @map("webhook_id") @db.Uuid
  event       String     @db.VarChar(50)
  payload     Json
  status      String     @default("pending") @db.VarChar(20)
  httpStatus  Int?       @map("http_status")
  attempts    Int        @default(0)
  nextRetryAt DateTime?  @map("next_retry_at")
  deliveredAt DateTime?  @map("delivered_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  webhook     ApiWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status, nextRetryAt])
  @@map("api_webhook_deliveries")
}

model ApiUsageLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apiKeyId   String   @map("api_key_id") @db.Uuid
  endpoint   String   @db.VarChar(200)
  method     String   @db.VarChar(10)
  statusCode Int?     @map("status_code")
  responseMs Int?     @map("response_ms")
  errorCode  String?  @map("error_code") @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at")
  apiKey     ApiKey   @relation(fields: [apiKeyId], references: [id])

  @@index([apiKeyId, createdAt])
  @@map("api_usage_logs")
}

model AdminLead {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessName       String    @map("business_name")
  category           String
  subCategory        String?   @map("sub_category")
  rating             Float
  reviewCount        Int       @map("review_count")
  ratingTrend        String    @map("rating_trend")
  reviewResponseRate String?   @map("review_response_rate")
  primarySource      String    @map("primary_source")
  address            String?
  city               String
  state              String
  zipCode            String?   @map("zip_code")
  phone              String?
  website            String?
  email              String?
  ownerName          String?   @map("owner_name")
  contactFound       Boolean   @default(false) @map("contact_found")
  hasOnlineOrdering  Boolean?  @map("has_online_ordering")
  hasSocialMedia     Boolean?  @map("has_social_media")
  lastReviewDate     String?   @map("last_review_date")
  conversionScore    Int       @default(0) @map("conversion_score")
  competitors        Json?
  teaserFindings     Json?     @map("teaser_findings")
  fullFindings       Json?     @map("full_findings")
  teaserReport       Json?     @map("teaser_report")
  status             String    @default("discovered")
  teaserSentAt       DateTime? @map("teaser_sent_at")
  teaserClickedAt    DateTime? @map("teaser_clicked_at")
  convertedAt        DateTime? @map("converted_at")
  discoveredAt       DateTime  @default(now()) @map("discovered_at")
  discoveredBy       String?   @map("discovered_by") @db.Uuid

  @@index([category])
  @@index([category, state])
  @@index([category, state, city])
  @@index([status])
  @@index([conversionScore])
  @@map("admin_leads")
}
